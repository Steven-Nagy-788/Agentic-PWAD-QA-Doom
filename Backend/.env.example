APP_NAME="Doom Agentic Testing Backend"
APP_ENV=development
DEBUG=true

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=doom_agentic_qa
POSTGRES_USER=doom_agentic
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://doom_agentic:change_me@localhost:5432/doom_agentic_qa

STORAGE_BASE=storage
STORAGE_DIR=storage
WAD_STORAGE_DIR=storage/wads
REPORT_STORAGE_DIR=storage/reports
RECORDING_STORAGE_DIR=storage/recordings
SCREENSHOT_STORAGE_DIR=storage/screenshots
ANALYSIS_STORAGE_DIR=storage/analysis

IWAD_USED=freedoom2
LLM_MODEL=gemini-3.1-flash-lite
GEMINI_API_KEY=
LLM_THROTTLE_SECONDS=2
GEMINI_RATE_LIMIT_CALLS_PER_MINUTE=15
LLM_INPUT_COST_PER_MILLION=0.10
LLM_OUTPUT_COST_PER_MILLION=0.40
MCP_DOOM_SSE_URL=http://localhost:8001/sse
MAX_RUN_TICKS=35000
DEFAULT_RUN_TICKS=3000
LIVE_FRAME_FPS=10
RECORDING_TELEMETRY_STRIDE=1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

SENTRY_DSN=

# Optional local convenience for scripts/init_db.sh.
# Prefer leaving this unset and entering sudo interactively when possible.
SUDO_PASSWORD=
